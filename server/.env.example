# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS / WS origins
CLIENT_ORIGIN=http://localhost:5173

# --- Database (MongoDB) ---
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=cipherchat

# --- Secrets (CHANGE THESE) ---
# Use long random strings in production, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=dev_access_secret_change_me_0123456789abcdef
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_fedcba9876543210

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
